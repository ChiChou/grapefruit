{
  "name": "igf",
  "version": "0.20.0",
  "description": "",
  "main": "dist/index.mjs",
  "bin": {
    "igf": "bin/igf"
  },
  "files": [
    "./dist",
    "./gui/dist",
    "./agent/dist"
  ],
  "scripts": {
    "dev:both": "bun scripts/dev.ts",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun --test",
    "prepack": "npm run build:npm",
    "install:bun": "cd agent && bun i && cd .. && cd gui && bun i",
    "build:gui": "cd gui && bun run build",
    "build:agent": "cd agent && bun run build",
    "build:assets": "bun run build:gui && bun run build:agent",
    "build:npm": "node scripts/build-npm.ts && tsdown --env.NODE_ENV=production",
    "build:cli": "bun scripts/build-bun.ts",
    "build:cross": "bun scripts/build-bun.ts cross"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@types/bun": "^1.3.6",
    "env-paths": "^3.0.0",
    "frida": "^17.6.1",
    "frida-remote-stream": "^6.0.3",
    "frida16": "npm:frida@^16.7.19",
    "hono": "^4.10.4",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "socket.io-client": "^4.8.1",
    "tsdown": "^0.20.1",
    "typescript": "^5.9.3"
  },
  "patchedDependencies": {
    "frida@17.5.1": "patches/frida@17.5.1.patch",
    "frida@17.6.1": "patches/frida@17.6.1.patch",
    "frida@16.7.19": "patches/frida@16.7.19.patch"
  },
  "trustedDependencies": [
    "frida",
    "frida16"
  ]
}
