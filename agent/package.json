{
  "name": "igf-agent",
  "version": "1.0.0",
  "description": "igf frida agent",
  "private": true,
  "main": "agent/index.ts",
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "build:fruity": "frida-compile src/fruity/index.ts -o dist/fruity.js",
    "build:droid": "frida-compile src/droid/index.ts -o dist/droid.js",
    "build:transport": "frida-compile src/transport.ts -o dist/transport.js",
    "watch:fruity": "npm run build:fruity -- --watch",
    "watch:droid": "npm run build:droid -- --watch",
    "watch:transport": "npm run build:transport -- --watch",
    "build": "npm run lint && npm run build:fruity && npm run build:droid && npm run build:transport",
    "prepare": "npm run build && npm run type",
    "lint": "eslint src/**/*.ts",
    "type:flags": "tsgo --declaration --experimentalDecorators --emitDeclarationOnly --outDir types --target es2019 --skipLibCheck",
    "type:fruity": "npm run type:flags -- src/fruity/registry.ts",
    "type:droid": "npm run type:flags -- src/droid/registry.ts",
    "type": "npm run type:fruity && npm run type:droid"
  },
  "devDependencies": {
    "@types/frida-gum": "^19.0.1",
    "@types/node": "^18.14.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@typescript/native-preview": "7.0.0-dev.20251108.1",
    "eslint": "^9.39.1",
    "frida-compile": "^19.0.4"
  },
  "dependencies": {
    "frida-java-bridge": "^7.0.10",
    "frida-objc-bridge": "^8.0.5",
    "frida-remote-stream": "^6.0.3",
    "frida-swift-bridge": "^3.0.2"
  },
  "trustedDependencies": [
    "frida"
  ]
}
