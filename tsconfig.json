{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": "./src",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "outDir": "dist",
    "paths": {
      "@shared/*": ["./shared/*"],
    },
  },
  "include": ["src/**/*", "shared/**/*", "src/index.ts"],
  "exclude": ["node_modules", "gui"],
}
